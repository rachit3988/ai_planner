{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["tasks", "questions", "notes"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "description", "estimated_minutes", "confidence"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "estimated_minutes": { "type": "number", "minimum": 5 },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": {
      "type": "string"
    }
  },
  "anyOf": [
    { "properties": { "tasks": { "minItems": 1 } } },
    { "properties": { "questions": { "minItems": 1 } } }
  ]
}
